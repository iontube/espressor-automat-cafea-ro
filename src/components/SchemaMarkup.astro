---
import products from '../data/products.json';

const siteUrl = 'https://espressor-automat-cafea.ro';
const now = new Date().toISOString();

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'espressor-automat-cafea.ro',
  url: siteUrl,
  description: 'Cele mai bune espressoare automate de cafea – comparatii, analize si recomandari actualizate',
  inLanguage: 'ro',
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'espressor-automat-cafea.ro',
  url: siteUrl,
  logo: `${siteUrl}/assets/images/logo-espressor-automat-cafea.webp`,
  description: 'Site independent de comparatii si recomandari de espressoare automate de cafea',
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'contact@espressor-automat-cafea.ro',
    contactType: 'customer service',
    availableLanguage: 'Romanian',
  },
  sameAs: [],
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Cel mai bun espressor automat de cafea boabe 2026 – comparatii si ghid de cumparare',
  description: 'Cel mai bun espressor automat de cafea boabe din 2026. 18 modele De\'Longhi, Philips, Krups si Saeco comparate: cu rasnita ceramica, cu spumare lapte, ieftine si profesionale.',
  image: `${siteUrl}/assets/images/og-cover.webp`,
  datePublished: '2026-03-29T08:00:00+03:00',
  dateModified: now,
  url: siteUrl,
  inLanguage: 'ro',
  author: {
    '@type': 'Person',
    name: 'Echipa espressor-automat-cafea.ro',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'espressor-automat-cafea.ro',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/favicon.svg`,
    },
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Acasa',
      item: siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Cele mai bune espressoare automate de cafea 2026',
      item: siteUrl,
    },
  ],
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Cele mai bune espressoare automate recomandate',
  numberOfItems: products.length,
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.name,
    url: `${siteUrl}/#review-${p.id}`,
  })),
};

const faqs = [
  {
    q: 'Care este cel mai bun espressor automat pentru acasa?',
    a: 'Depinde de buget si preferinte. Pentru majoritatea, un De\'Longhi Magnifica sau Philips seria 3200 ofera cel mai bun raport calitate-pret.',
  },
  {
    q: 'Merita sa cumpar un espressor automat sau mai bine unul manual?',
    a: 'Daca vrei confort si consistenta – automat. Un espressor automat face totul singur in 60 de secunde, de la macinare la extractie.',
  },
  {
    q: 'Cat costa o cafea la espressor automat?',
    a: 'In medie, 0.50-1 RON per ceasca. La 2 cafele pe zi, economisesti peste 4.000 RON pe an fata de cafeaua de la cafenea.',
  },
  {
    q: 'Ce boabe de cafea sa folosesc la espressor automat?',
    a: 'Boabe proaspat prajite, de preferinta cu maxim 4-6 saptamani de la prajire. Un blend 80% Arabica / 20% Robusta e un punct bun de start.',
  },
  {
    q: 'Cat de des trebuie curatat un espressor automat?',
    a: 'Tava de scurgere – zilnic. Grupul de preparare – saptamanal. Decalcifiere – la 2-3 luni.',
  },
  {
    q: 'Ce inseamna 15 bari presiune la un espressor?',
    a: '15 bari este presiunea maxima a pompei. Un espresso bun se extrage la ~9 bari. Orice espressor cu pompa de 15 bari e suficient.',
  },
  {
    q: 'Espressorul automat face cafea la fel de buna ca la cafenea?',
    a: 'Cu boabe bune si macinare corecta, da – foarte aproape. Un espressor automat ofera consistenta: aceeasi cafea buna, de fiecare data.',
  },
  {
    q: 'Care sunt cele mai fiabile branduri de espressoare automate?',
    a: 'De\'Longhi si Philips/Saeco domina piata si au cel mai bun service in Romania. Jura si Krups sunt de asemenea fiabile.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
};
---
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
