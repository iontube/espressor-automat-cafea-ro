---
import products from '../data/products.json';
const count = products.length;
---
<section class="hero" id="top">
  <div class="hero-bg">
    <img src="/assets/images/cele-mai-bune-espressoare-automate-cafea-2026.webp" alt="Cele mai bune espressoare automate de cafea 2026" width="1792" height="1024" fetchpriority="high" />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-container">
    <div class="hero-badge"><time datetime="2026-03">Actualizat martie 2026</time> &middot; {count} modele analizate</div>

    <h1>Cel mai bun espressor automat cafea boabe – {count} modele comparate</h1>

    <p class="hero-p">Am comparat {count} <strong>espressoare automate cu rasnita</strong> de la De'Longhi, Philips, Krups si Saeco – de la modele <strong>ieftine sub 1.500 RON</strong> pana la <strong>espressoare automate profesionale</strong> cu <strong>rasnita ceramica</strong> si <strong>spumare automata a laptelui</strong>. Pentru fiecare am verificat calitatea extractiei, cat de usor se curata si daca pretul se justifica.</p>

    <div class="hero-ctas">
      <a href="#produse" class="btn btn-gold btn-lg">
        Vezi toate espressoarele
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 3v10M4 9l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="#ghid" class="btn btn-outline btn-lg">Cum alegi espressorul potrivit</a>
    </div>

    <div class="hero-picks">
      <div class="hero-pick">
        <span class="hero-pick-label">Top espressor automat raport pret</span>
        <span class="hero-pick-name">De'Longhi Magnifica S</span>
        <a href="#review-delonghi-magnifica-s-ecam-22-112-b" class="hero-pick-link">Citeste analiza →</a>
      </div>
      <div class="hero-pick">
        <span class="hero-pick-label">Cel mai bun pentru cappuccino</span>
        <span class="hero-pick-name">Philips EP2231 LatteGo</span>
        <a href="#review-philips-ep2231-40" class="hero-pick-link">Citeste analiza →</a>
      </div>
      <div class="hero-pick">
        <span class="hero-pick-label">Cel mai bun premium</span>
        <span class="hero-pick-name">Philips EP5543 seria 5500</span>
        <a href="#review-philips-ep5543-90" class="hero-pick-link">Citeste analiza →</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero{position:relative;overflow:hidden;padding:7rem 0 3.5rem}

  .hero-bg{position:absolute;inset:0;z-index:0}
  .hero-bg img{width:100%;height:100%;object-fit:cover;object-position:center 20%}
  .hero-overlay{position:absolute;inset:0;background:linear-gradient(180deg,color-mix(in srgb,var(--c-bg) 40%,transparent) 0%,color-mix(in srgb,var(--c-bg) 75%,transparent) 40%,color-mix(in srgb,var(--c-bg) 92%,transparent) 70%,var(--c-bg) 100%)}
  @media(prefers-color-scheme:light){
    .hero-overlay{background:linear-gradient(180deg,color-mix(in srgb,var(--c-bg) 60%,transparent) 0%,color-mix(in srgb,var(--c-bg) 85%,transparent) 30%,var(--c-bg) 60%)}
    .hero-bg img{opacity:.4}
  }

  .hero-container{position:relative;z-index:1;max-width:900px}

  .hero-badge{display:inline-flex;align-items:center;gap:.4rem;font-size:.65rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--c-gold);background:rgba(200,169,110,.1);border:1px solid rgba(200,169,110,.2);padding:.35rem .85rem;border-radius:100px;margin-bottom:1.75rem;backdrop-filter:blur(4px)}

  .hero h1{font-size:clamp(2rem,5vw,3.25rem);line-height:1.1;letter-spacing:-.03em;margin-bottom:1.5rem;max-width:750px}

  .hero-p{font-size:1.05rem;line-height:1.85;color:var(--c-text-mid);max-width:640px;margin-bottom:2.5rem}

  .hero-ctas{display:flex;gap:.75rem;flex-wrap:wrap;margin-bottom:3.5rem}

  .hero-picks{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem}
  .hero-pick{background:rgba(255,255,255,.04);border:1px solid rgba(200,169,110,.15);border-radius:var(--radius-sm);padding:1.1rem 1.25rem;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);transition:all .2s var(--transition)}
  .hero-pick:hover{border-color:var(--c-gold);background:rgba(200,169,110,.06)}
  .hero-pick-label{display:block;font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--c-gold);margin-bottom:.35rem}
  .hero-pick-name{display:block;font-size:.95rem;font-weight:700;color:var(--c-text);line-height:1.3;margin-bottom:.4rem}
  .hero-pick-link{font-size:.78rem;color:var(--c-gold);font-weight:600;opacity:.7;transition:opacity .2s}
  .hero-pick-link:hover{opacity:1}

  @media(max-width:768px){
    .hero{min-height:auto;padding:5rem 0 2rem}
    .hero-overlay{background:linear-gradient(180deg,color-mix(in srgb,var(--c-bg) 50%,transparent) 0%,color-mix(in srgb,var(--c-bg) 85%,transparent) 30%,var(--c-bg) 55%)}
    .hero-badge{font-size:.6rem;padding:.3rem .7rem}
    .hero h1{font-size:1.75rem}
    .hero-p{font-size:.93rem;margin-bottom:2rem}
    .hero-ctas{margin-bottom:2rem}
    .hero-ctas .btn{width:100%;justify-content:center}
    .hero-picks{grid-template-columns:1fr;gap:.5rem}
    .hero-pick{padding:.85rem 1rem}
    .hero-pick-name{font-size:.88rem}
  }
</style>
