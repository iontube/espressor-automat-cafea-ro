---
import ProductCard from './ProductCard.astro';
import products from '../data/products.json';
---
<section class="section" id="produse">
  <div class="container">
    <div class="section-eyebrow">{products.length} espressoare analizate</div>
    <h2 class="section-title">Top espressoare automate de cafea boabe 2026 – pentru acasa si birou</h2>
    <p class="section-desc"><strong>Espressor automat cafea boabe</strong> de la De'Longhi, Philips, Krups, Saeco, Melitta si Gaggia – <strong>espressor automat cu rasnita ceramica</strong>, <strong>cu spumare lapte</strong> si la diferite preturi. Specificatii verificate si pareri reale. Include si un <strong>espressor automat Tchibo</strong> si modele accesibile pentru cine cauta un <strong>espressor automat ieftin si bun</strong>.</p>

    <div class="promo-bar">
      <a href="/out/oferte-espressoare" class="promo-link promo-oferte" target="_blank" rel="nofollow noopener sponsored">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
        <span>Oferte espressoare</span>
        <svg class="promo-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="/out/top-favorite" class="promo-link promo-favorite" target="_blank" rel="nofollow noopener sponsored">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <span>Top favorite</span>
        <svg class="promo-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="/out/super-pret" class="promo-link promo-pret" target="_blank" rel="nofollow noopener sponsored">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        <span>Super pret</span>
        <svg class="promo-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="/out/noutati-espressoare" class="promo-link promo-noutati" target="_blank" rel="nofollow noopener sponsored">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        <span>Noutati</span>
        <svg class="promo-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <div class="products-list">
      {products.map((product, i) => <ProductCard product={product} eager={i < 3} />)}
    </div>
  </div>
</section>
