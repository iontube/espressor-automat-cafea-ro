---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
}

const { title, description, canonical = Astro.url.href, noindex = false } = Astro.props;
const siteName = 'espressor-automat-cafea.ro';
const ogImage = `${Astro.site}assets/images/og-cover.webp`;
const now = new Date().toISOString();
---
<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>
  <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"}>
  <link rel="icon" href="/favicon.ico" sizes="48x48">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#141210" media="(prefers-color-scheme: dark)">
  <meta name="theme-color" content="#faf8f6" media="(prefers-color-scheme: light)">
  <link rel="preload" href="/assets/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin>
  <meta property="og:type" content="article">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonical}>
  <meta property="og:site_name" content={siteName}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:image:width" content="1536">
  <meta property="og:image:height" content="1024">
  <meta property="og:locale" content="ro_RO">
  <meta property="article:published_time" content="2026-03-29T08:00:00+03:00">
  <meta property="article:modified_time" content={now}>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>
</head>
<body>
  <a href="#continut-principal" class="skip-link">Sari la continut</a>
  <slot />

  <button class="back-top" id="backTop" aria-label="Inapoi sus">↑</button>
  <script>
    (function(){
      const btn = document.getElementById('backTop');
      if(!btn) return;
      window.addEventListener('scroll',function(){
        if(window.scrollY > 600){btn.classList.add('visible')}else{btn.classList.remove('visible')}
      },{passive:true});
      btn.addEventListener('click',function(){window.scrollTo({top:0,behavior:'smooth'})});
    })();
  </script>

  <div class="cookie-banner" id="cookieBanner" role="dialog" aria-label="Consimtamant cookies">
    <div class="cookie-banner-inner">
      <div class="cookie-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--c-gold)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><circle cx="8" cy="9" r="1" fill="var(--c-gold)"/><circle cx="15" cy="8" r="1" fill="var(--c-gold)"/><circle cx="10" cy="14" r="1" fill="var(--c-gold)"/><circle cx="16" cy="13" r="1" fill="var(--c-gold)"/></svg>
      </div>
      <div class="cookie-text">
        <p class="cookie-title">Cookies</p>
        <p>Folosim cookies strict pentru analiza traficului. Datele nu sunt partajate cu terti. <a href="/politica-cookies/" rel="nofollow">Detalii</a></p>
      </div>
      <div class="cookie-banner-actions">
        <button class="btn btn-gold btn-sm" id="cookieAccept">Accept</button>
        <button class="btn btn-outline btn-sm" id="cookieDecline">Nu</button>
      </div>
    </div>
  </div>

  <script>
    const banner = document.getElementById('cookieBanner');
    if (banner && !localStorage.getItem('cookie-consent')) {
      banner.classList.add('is-visible');
    }
    document.getElementById('cookieAccept')?.addEventListener('click', () => {
      localStorage.setItem('cookie-consent', 'accepted');
      banner?.classList.remove('is-visible');
    });
    document.getElementById('cookieDecline')?.addEventListener('click', () => {
      localStorage.setItem('cookie-consent', 'declined');
      banner?.classList.remove('is-visible');
    });
  </script>
</body>
</html>

<style is:global>
  .skip-link{position:absolute;top:-100%;left:1rem;padding:.5rem 1rem;background:var(--c-gold);color:var(--c-bg);border-radius:0 0 var(--radius-sm) var(--radius-sm);font-size:.85rem;font-weight:600;z-index:999;transition:top .2s}
  .skip-link:focus{top:0}
  .cookie-banner{position:fixed;bottom:0;left:0;right:0;z-index:300;transform:translateY(100%);transition:transform .4s cubic-bezier(.4,0,.2,1);pointer-events:none}
  .cookie-banner.is-visible{transform:translateY(0);pointer-events:auto}
  .cookie-banner-inner{max-width:440px;margin:0 auto 1rem;background:var(--c-surface-card);border:1px solid var(--c-border);border-radius:var(--radius);padding:1rem 1.25rem;box-shadow:var(--shadow-lg);display:flex;align-items:center;gap:1rem}
  .cookie-icon{flex-shrink:0}
  .cookie-text{flex:1}
  .cookie-text .cookie-title{font-size:.78rem;font-weight:700;color:var(--c-text);margin:0 0 .15rem}
  .cookie-text p{margin:0;font-size:.72rem;color:var(--c-text-light);line-height:1.45}
  .cookie-text a{color:var(--c-gold);font-weight:600}
  .cookie-banner-actions{display:flex;gap:.35rem;flex-shrink:0}
  @media(max-width:580px){.cookie-banner-inner{margin:.5rem;flex-wrap:wrap}.cookie-banner-actions{width:100%;justify-content:flex-end}}
</style>
