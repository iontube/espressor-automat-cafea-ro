---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="404 – Pagina nu exista" description="Pagina cautata nu a fost gasita pe espressor-automat-cafea.ro." noindex={true}>
  <Navigation />
  <main class="legal-page" id="continut-principal">
    <div class="container" style="text-align:center;padding:6rem 1.5rem">
      <p style="font-size:5rem;font-weight:800;color:var(--c-gold);margin-bottom:.5rem;line-height:1">404</p>
      <h1 style="font-size:1.5rem;margin-bottom:1rem">Pagina nu exista</h1>
      <p style="color:var(--c-text-mid);max-width:420px;margin:0 auto 2rem">Ne pare rau, dar pagina pe care o cauti nu a fost gasita. Este posibil sa fi fost mutata sau stearsa.</p>
      <a href="/" class="btn btn-gold">Inapoi la pagina principala</a>
    </div>
  </main>
  <Footer />
</Layout>
